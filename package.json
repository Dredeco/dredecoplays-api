{
  "name": "dredecoplays-api",
  "version": "1.0.0",
  "description": "API REST para gerenciamento de blog GamerZone",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "node scripts/guard-dev.js && npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "fresh": "node scripts/guard-dev.js && npm run migrate:undo && npm run migrate && npm run seed",
    "createdb": "node scripts/createdb.js",
    "verify-thumbnails": "node scripts/verify-thumbnails.js",
    "test-thumbnails-api": "node scripts/test-thumbnails-api.js",
    "test-upload": "node scripts/test-upload.js",
    "test": "cross-env NODE_ENV=test jest",
    "test:prepare": "cross-env NODE_ENV=test node scripts/createdb.js && cross-env NODE_ENV=test npx sequelize-cli db:migrate && cross-env NODE_ENV=test npx sequelize-cli db:seed:undo:all && cross-env NODE_ENV=test npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.9.2",
    "sequelize": "^6.37.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.2",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
