NODE_ENV=production
PORT=3000

DB_HOST=localhost
DB_PORT=3306
DB_USER=seu_usuario_mysql
DB_PASS=sua_senha_mysql
DB_NAME=nome_do_banco

JWT_SECRET=troque_por_uma_chave_muito_segura_em_producao
JWT_EXPIRES_IN=7d

# URL base da API (opcional). Use em produção atrás de proxy para URLs de upload corretas.
# Ex: https://api.dredecoplays.com
# BASE_URL=

# URL do site (front-end) — usada em sitemap, RSS e metadados SEO
# FRONTEND_URL=https://dredecoplays.com.br

# URL absoluta da logo para o feed RSS (opcional)
# SITE_LOGO_URL=https://dredecoplays.com.br/logo.png

UPLOAD_DIR=public/uploads
MAX_FILE_SIZE=5242880

# Instagram Graph API — Webhooks (Meta Developer Console → Instagram → Configurar webhooks)
# Callback URL: https://api.dredecoplays.com.br/webhooks/instagram
# O mesmo valor em "Verificar token" no painel da Meta.
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Recomendado em produção: App Secret do app Meta (validação X-Hub-Signature-256)
# INSTAGRAM_APP_SECRET=

# Publicação no Instagram pelo painel (POST manual — requer permissões e App Review)
# Token de longa duração com instagram_basic, instagram_content_publish, pages_show_list, etc.
# INSTAGRAM_ACCESS_TOKEN=
# ID da conta Instagram Business (Graph API — ex.: 17841467074241400)
# INSTAGRAM_BUSINESS_ACCOUNT_ID=
# Se true e video_json tiver contentUrl HTTPS, publica como Reels; senão post com thumbnail no feed
# INSTAGRAM_PUBLISH_REELS=true
# Opcional — default v21.0
# INSTAGRAM_GRAPH_VERSION=v21.0
